# SSRDOG Custom Stable Override
# 用法：把机场订阅作为主配置；把本文件作为 Stash Override 启用。
# 目的：订阅更新时只更新 proxies 节点；本地自定义 DNS、策略组、链式代理、规则不被覆盖。
# 注意：proxy-groups / rule-providers / rules 使用 #!replace，避免订阅自带分组/规则与本地规则冲突。

name: SSRDOG Custom Stable Override
desc: 保留自定义分流、规则、链式代理、券商分流与 DNS；Firstrade 默认避开链式代理，嘉信保留链式代理优先。
author: Generated for Adziol
date: '2026-06-25'
version: 1.2.0
mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
ipv6: false
unified-delay: true

profile: #!replace
  store-selected: true
  tracing: false
  store-fake-ip: false

hosts: #!replace
  localhost.localhost: 127.0.0.1

dns: #!replace
  enable: true
  ipv6: false
  listen: 0.0.0.0:1053
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  use-hosts: true
  default-nameserver:
  - 223.5.5.5
  - 119.29.29.29
  proxy-server-nameserver:
  - 223.5.5.5
  - 119.29.29.29
  nameserver:
  - 223.5.5.5
  - 223.6.6.6
  - 119.29.29.29
  fallback:
  - 1.1.1.1
  - 8.8.8.8
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
    - 240.0.0.0/4
  fake-ip-filter:
  - '*.lan'
  - '*.local'
  - localhost.ptlogin2.qq.com
  - dns.msftncsi.com
  - '*.msftconnecttest.com'
  - '*.msftncsi.com'
  - '*.srv.nintendo.net'
  - '*.stun.playstation.net'
  - xbox.*.microsoft.com
  - '*.xboxlive.com'
  - time.windows.com
  - pool.ntp.org
  - '*.snssdk.com'
  - '*.toutiao.com'
  - '*.ixigua.com'
  - '*.pstatp.com'
  - '*.byteimg.com'
  - '*.bytedance.com'
  - '*.douyin.com'
  - '*.amemv.com'
  - '*.zijieapi.com'
  - '*.bdurl.net'

# 这里不要放订阅节点，只放你自己的固定二跳 SOCKS5；订阅里的节点会继续由主配置更新。
proxies:
  - name: US-SOCKS5-Raw
    type: socks5
    server: 64.32.187.244
    port: 443
    username: QsAGnasbSCym
    password: RhK3h9xxi2
    udp: true
    benchmark-disabled: true

